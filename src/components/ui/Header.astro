---
import type { NavigationData } from '../../lib/types';

interface Props {
  nav: NavigationData;
}

const { nav } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="nav-wrap">
  <nav class="nav container" aria-label="Main navigation">
    <a href="/" class="logo" aria-label={`${nav.logoText} home`}>
      {nav.logoImageUrl
        ? <img src={nav.logoImageUrl} alt={`${nav.logoText} logo`} width="120" height="32" />
        : <img src="/image-removebg-preview.png" alt={`${nav.logoText} logo`} width="120" height="32" />}
    </a>

    <div class="nav-pill">
      <button id="nav-toggle" class="nav-hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
        <span></span><span></span><span></span>
      </button>

      <ul id="nav-menu" class="nav-links" role="list" aria-hidden="false">
        {nav.links.map(link => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <li><a href={link.href} class={`nav-link${isActive ? ' active' : ''}`}>{link.label}</a></li>
          );
        })}
      </ul>
    </div>

    <a href={nav.ctaHref} class="btn-primary nav-cta">{nav.ctaLabel}</a>
  </nav>
</header>

<style>
  .nav-wrap {
    position: sticky; top: 0; z-index: 100;
    padding: 12px 0;
  }
  .nav {
    display: flex; align-items: center; gap: 1.25rem; height: 52px;
  }
  .logo { display: flex; align-items: center; gap: 8px; flex-shrink: 0; z-index: 1; }
  .logo img { display: block; height: 28px; width: auto; }

  /* ── Pill nav ── */
  .nav-pill {
    display: flex; align-items: center;
    margin-inline: auto;
    padding: 5px 6px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .nav-links { display: flex; list-style: none; gap: 2px; }
  .nav-link {
    padding: 8px 18px; border-radius: 40px;
    font-size: .84rem; font-weight: 500; color: var(--muted);
    transition: color .2s, background .2s, box-shadow .2s;
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--text); background: rgba(255, 255, 255, 0.06); }
  .nav-link.active {
    color: #fff;
    background: var(--brand-color);
    box-shadow: 0 2px 12px rgba(197, 36, 81, 0.35);
  }

  .nav-hamburger { display: none; flex-direction: column; gap: 5px; padding: 8px; }
  .nav-hamburger span { display: block; width: 21px; height: 2px; background: var(--text); border-radius: 2px; }
  .nav-cta { margin-left: auto; white-space: nowrap; flex-shrink: 0; }

  @media (max-width: 768px) {
    .nav-wrap { padding: 10px 0; }
    .nav-pill {
      position: absolute; top: 56px; left: 12px; right: 12px;
      flex-direction: column; padding: 12px;
      border-radius: 16px;
    }
    .nav-hamburger { display: flex; }
    .nav-links {
      display: none; flex-direction: column; width: 100%;
      gap: 4px; padding-top: 8px;
    }
    .nav-links.open { display: flex; }
    .nav-link { width: 100%; text-align: center; padding: 10px 16px; }
    .nav-cta { display: none; }
  }
</style>
