---
import Base from '../layouts/Base.astro';
import { getContactPage } from '../lib/content';
import { richTextToHtml } from '../lib/strapi';

const contact = await getContactPage();
const hero = contact.hero?.[0] ?? null;
const contactInfo = contact.Contact ?? null;
const contactItems = contactInfo?.items ?? [];
---
<Base title={`Contact Us | ${contactInfo?.CompanyName || 'Clixerfy'}`} description="Get in touch with Clixerfy to protect your ad spend from click fraud.">
<main>

  {/* Hero Section */}
  {hero && (
    <section class="contact-hero">
      <div class="contact-hero-bg" aria-hidden="true"><div class="contact-hero-particles" aria-hidden="true"></div></div>
      <div class="container contact-hero-inner">
        <div class="contact-hero-content">
          {hero.titleText && <h1 class="reveal">{hero.titleText}</h1>}
          {hero.subtitle && <div class="contact-hero-sub reveal" set:html={richTextToHtml(hero.subtitle)}></div>}
          {hero.richtext && <div class="contact-hero-text reveal" set:html={richTextToHtml(hero.richtext)}></div>}
        </div>
      </div>
    </section>
  )}

  {/* Contact Info + Form Section */}
  <section class="section contact-main-section">
    <div class="container">
      <div class="contact-grid">

        {/* Contact Info Cards */}
        {contactItems.length > 0 && (
          <div class="contact-info-col">
            <h2 class="reveal">Get In Touch</h2>
            <div class="contact-info-cards">
              {contactItems.map((item: any, i: number) => (
                <div class="contact-info-card reveal" style={`transition-delay:${i * 80}ms`}>
                  {item.icon?.iconData && (
                    <div class="contact-info-icon">
                      <svg viewBox={`0 0 ${item.icon.width || 24} ${item.icon.height || 24}`} set:html={item.icon.iconData} />
                    </div>
                  )}
                  <div class="contact-info-text">
                    {item.label && <span class="contact-info-label">{item.label}</span>}
                    {item.value && (
                      item.value.includes('@')
                        ? <a href={`mailto:${item.value}`} class="contact-info-value">{item.value}</a>
                        : item.value.startsWith('http')
                          ? <a href={item.value} target="_blank" rel="noopener" class="contact-info-value">{item.value}</a>
                          : <span class="contact-info-value">{item.value}</span>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Contact Form */}
        <div class="contact-form-col">
          <h2 class="reveal">Send Us a Message</h2>
          <form class="contact-form reveal" id="contact-form" method="POST" action="/api/contact">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" required placeholder="John Doe" />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="john@company.com" />
              </div>
            </div>
            <div class="form-group">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" placeholder="Your Company" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell us about your needs..."></textarea>
            </div>
            <button type="submit" class="btn-primary btn-lg contact-submit">
              {hero?.CTAButtonText || 'Send Message'}
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</main>
</Base>

<style>
  /* Hero */
  .contact-hero { position: relative; overflow: hidden; padding-block: clamp(3.5rem, 8vw, 6rem); }
  .contact-hero-bg { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(230,48,48,.14) 0%, transparent 70%), linear-gradient(180deg, #0a0a0a 0%, #0d0000 60%, #0a0a0a 100%); }
  .contact-hero-particles { position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(230,48,48,.65) 1px, transparent 1px), radial-gradient(circle, rgba(230,48,48,.4) 1.5px, transparent 1.5px); background-size: 120px 80px, 200px 150px; opacity: .7; }
  .contact-hero-inner { position: relative; max-width: 800px; text-align: center; }
  .contact-hero-content h1 { font-family: var(--font-head); font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 800; line-height: 1.15; margin-bottom: 1rem; }
  .contact-hero-sub { font-size: 1.1rem; color: var(--muted); margin-bottom: 1.5rem; }
  .contact-hero-text { font-size: .93rem; color: var(--muted); line-height: 1.8; max-width: 600px; margin-inline: auto; }

  /* Main Contact Section */
  .contact-main-section { padding-block: clamp(3rem, 6vw, 5rem); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; align-items: start; }
  .contact-grid h2 { font-family: var(--font-head); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin-bottom: 1.5rem; }

  /* Contact Info Cards */
  .contact-info-cards { display: flex; flex-direction: column; gap: 1rem; }
  .contact-info-card { display: flex; align-items: center; gap: 1.2rem; background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 14px; padding: 1.5rem; transition: border-color .18s, transform .18s; }
  .contact-info-card:hover { border-color: var(--brand-color); transform: translateY(-2px); }
  .contact-info-card:hover .contact-info-icon svg { color: var(--brand-color); }
  .contact-info-icon { width: 48px; height: 48px; min-width: 48px; border-radius: 12px; background: rgba(230,48,48,.08); border: 1px solid rgba(230,48,48,.16); display: flex; align-items: center; justify-content: center; transition: all .18s; }
  .contact-info-icon svg { width: 22px; height: 22px; transition: color .18s; }
  .contact-info-text { display: flex; flex-direction: column; gap: .2rem; }
  .contact-info-label { font-size: .78rem; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
  .contact-info-value { font-size: .92rem; color: #fff; font-weight: 600; text-decoration: none; transition: color .18s; word-break: break-word; }
  a.contact-info-value:hover { color: var(--brand-color); }

  /* Contact Form */
  .contact-form { display: flex; flex-direction: column; gap: 1.2rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  .form-group { display: flex; flex-direction: column; gap: .4rem; }
  .form-group label { font-size: .82rem; font-weight: 600; color: var(--muted); }
  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: .85rem 1rem;
    color: #fff;
    font-size: .9rem;
    font-family: inherit;
    transition: border-color .18s, box-shadow .18s;
    outline: none;
    resize: vertical;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder { color: rgba(255,255,255,.3); }
  .form-group input:focus,
  .form-group textarea:focus { border-color: var(--brand-color); box-shadow: 0 0 0 3px rgba(230,48,48,.1); }
  .contact-submit { align-self: flex-start; margin-top: .5rem; cursor: pointer; border: none; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
