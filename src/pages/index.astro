---
import Base from '../layouts/Base.astro';

const features = [
  {
    title: "Real-Time Threat Detection and Response",
    desc: "Continuously monitors your website for suspicious activity, automatically blocking threats before they cause damage.",
    icon: `<path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/><path d="M9 12l2 2 4-4" stroke-width="1.5" fill="none"/>`,
    large: true,
  },
  {
    title: "Monitor File Changes & Suspicious Activity",
    desc: "Tracks every file modification, alerting you instantly when unauthorized changes are detected.",
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
    large: false,
  },
  {
    title: "Block Malicious Traffic & Bot",
    desc: "Identifies and blocks automated bot traffic, scrapers, and DDoS attempts in real time.",
    icon: `<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>`,
    large: false,
  },
  {
    title: "Designed for High Quality Performances",
    desc: "Security without the slowdown — lightweight integration keeps your site fast and your scores high.",
    icon: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
    large: false,
  },
];

const stats = [
  { value: "1000+", label: "Websites Protected", icon: `<path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/>` },
  { value: "99.9%", label: "Threats Detected", icon: `<circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/>` },
  { value: "24/7",  label: "Real Time Monitoring", icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>` },
  { value: "120+",  label: "Countries Served", icon: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>` },
];

const products = [
  { title: "Web Application Firewall",  icon: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>` },
  { title: "Malware Removal",           icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>` },
  { title: "Ad Fraud Blocker",          icon: `<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>` },
  { title: "Vulnerability Scanner",     icon: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>` },
  { title: "WordPress File Scanner",    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>` },
];

const cards = [
  { title: "Real-Time Threat Detection and Response",  desc: "Continuously monitors and blocks threats before they cause damage to your site or reputation.", color: "#1a0808" },
  { title: "Monitor File Changes & Suspicious Activity", desc: "Get instant alerts for unauthorized file changes across your entire web infrastructure.", color: "#1a0505" },
  { title: "Block Malicious Traffic & Bot",            desc: "Advanced bot detection stops scrapers, credential stuffers, and DDoS attacks automatically.", color: "#0d0d0d" },
  { title: "Designed for High Quality Performances",  desc: "Zero-latency security layer that keeps your PageSpeed scores green while keeping hackers out.", color: "#0a0a0a" },
];

const testimonials = [
  { name: "Alex Johnson", role: "CTO at TechCorp",       stars: 5, text: "Clixerfy's real-time detection identified a breach attempt within seconds. Our uptime has never been better since deploying their WAF solution." },
  { name: "Maria Santos", role: "Lead Dev at Storefront", stars: 5, text: "The WordPress file scanner caught a malicious plugin injection that our old security suite completely missed. Absolutely invaluable." },
  { name: "James Wei",    role: "DevOps Engineer",        stars: 5, text: "Setup took under 10 minutes and the bot blocker reduced our server load by 40%. Best security investment we've made this year." },
];

const footerLinks = {
  Products:  ["Web Application Firewall", "Malware Removal", "HelpCenter", "WordPress File Scanner", "AdFraud Blocker"],
  Resources: ["Blog", "Guides", "HelpCenter", "System Status"],
  Company:   ["About Us", "Pricing", "Contact Us", "Careers"],
};
---
<Base>

<!-- ── NAV ── -->
<header class="nav-wrap">
  <nav class="nav container" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="Clixerfy home">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e63030" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
      <span>clixerfy</span>
    </a>

    <button id="nav-toggle" class="nav-hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>

    <ul id="nav-menu" class="nav-links" role="list" aria-hidden="false">
      <li><a href="#home"     class="nav-link active">Home</a></li>
      <li><a href="#about"    class="nav-link">About Us</a></li>
      <li><a href="#products" class="nav-link">Product</a></li>
      <li><a href="#pricing"  class="nav-link">Pricing</a></li>
      <li><a href="#contact"  class="nav-link">Contact</a></li>
    </ul>

    <a href="#trial" class="btn-primary nav-cta">Get Started ↗</a>
  </nav>
</header>

<main id="home">

  <!-- ── HERO ──
       FIX: No CSS background animations here. Background is a static CSS gradient
       + a single inlined SVG pattern — zero reflow, zero JS, paints instantly. -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">

      <div class="hero-content">
        <div class="hero-badge">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/></svg>
          Modular security tools for modern websites
        </div>
        <!--
          FIX: h1 is the LCP element. It has no animation-delay, no opacity:0,
          no transform applied at paint time — renders on first frame.
        -->
        <h1 id="hero-heading">
          Protect Your Website from <em>Attacks, Malware &amp; Ad Fraud</em>
        </h1>
        <p class="hero-sub">Clixerfy provides powerful tools to keep your website safe, fast and trusted.</p>
        <div class="hero-actions">
          <a href="#trial" id="trial" class="btn-primary btn-lg">Start Free Trial ↗</a>
        </div>
        <div class="hero-trust">
          <span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/></svg>
            No Credit Card Required
          </span>
          <span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Free 7 Day Trial
          </span>
        </div>
      </div>

      <!--
        FIX: Shield visual uses only translateY (GPU layer) + opacity blink.
        NO scale animations, NO rotate — those trigger layout reflow on mobile.
      -->
      <div class="hero-visual" aria-hidden="true">
        <div class="shield-wrap">
          <div class="ring ring-1"></div>
          <div class="ring ring-2"></div>
          <svg class="shield-icon" width="110" height="130" viewBox="0 0 120 140" fill="none">
            <path d="M60 5 L110 25 L110 75 C110 105 85 130 60 138 C35 130 10 105 10 75 L10 25 Z" fill="#e63030" opacity="0.12" stroke="#e63030" stroke-width="1.5"/>
            <path d="M60 18 L100 34 L100 75 C100 100 80 122 60 130 C40 122 20 100 20 75 L20 34 Z" fill="#e63030" opacity="0.22"/>
            <path d="M44 70 L55 82 L78 58" stroke="#fff" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="60" cy="70" r="22" fill="none" stroke="rgba(230,48,48,.35)" stroke-width="1.5"/>
          </svg>
          <div class="dot dot-a"></div>
          <div class="dot dot-b"></div>
          <div class="dot dot-c"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── FEATURES GRID ── -->
  <section class="section" id="about" aria-labelledby="feat1-heading">
    <div class="container">
      <h2 id="feat1-heading" class="section-title reveal">Built for Modern <em>Web Threats</em></h2>
      <div class="feat-grid">
        {features.map((f, i) => (
          <article class={`feat-card reveal ${f.large ? 'feat-large' : ''}`} style={`transition-delay:${i*60}ms`}>
            <div class="feat-icon" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
            </div>
            <h3 class="feat-title">{f.title}</h3>
            <p class="feat-desc">{f.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WHY TRUST ── -->
  <section class="section trust-section" id="why" aria-labelledby="trust-heading">
    <div class="container">
      <div class="trust-inner">
        <div class="trust-copy reveal">
          <h2 id="trust-heading">Why Teams Trust <em>Clixerfy</em></h2>
          <p>Security is often viewed as a barrier, but we see it as an enabler. We've designed our suite of tools to integrate effortlessly into your existing workflow, providing "invisible" yet ironclad protection.</p>
        </div>
        <div class="stats-row" role="list">
          {stats.map((s, i) => (
            <div class="stat-item reveal" style={`transition-delay:${i*55}ms`} role="listitem">
              <div class="stat-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#e63030" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </div>
              <strong class="stat-value">{s.value}</strong>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRODUCTS ── -->
  <section class="section" id="products" aria-labelledby="prod-heading">
    <div class="container">
      <h2 id="prod-heading" class="section-title reveal">Built for Modern <em>Web Threats</em></h2>
      <div class="prod-grid">
        {products.map((p, i) => (
          <article class="prod-card reveal" style={`transition-delay:${i*55}ms`}>
            <div class="prod-icon" aria-hidden="true">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#e63030" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} />
            </div>
            <h3 class="prod-title">{p.title}</h3>
            <p class="prod-desc">Our AI learns your preferences and adapts to your website's unique threat landscape.</p>
            <a href="#contact" class="prod-link">Learn More <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── THREAT CARDS ── -->
  <section class="section cards-section" aria-labelledby="cards-heading">
    <div class="container">
      <h2 id="cards-heading" class="section-title reveal">Built for Modern <em>Web Threats</em></h2>
      <p class="section-sub reveal">Comprehensive security layers designed to keep your digital assets safe, responsive, and resilient against evolving cyber risks</p>
      <div class="threat-cards" role="list">
        {cards.map((c, i) => (
          <article class="threat-card reveal" style={`background:${c.color};transition-delay:${i*60}ms`} role="listitem">
            <div class="tc-icon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#e63030" stroke-width="2" stroke-linecap="round"><path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/></svg>
            </div>
            <h3 class="tc-title">{c.title}</h3>
            <p class="tc-desc">{c.desc}</p>
            <a href="#contact" class="tc-link">Learn More <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA BANNER ── -->
  <section class="cta-section" id="pricing" aria-labelledby="cta-heading">
    <div class="container cta-inner">
      <h2 id="cta-heading" class="reveal">Secure Your Website Today</h2>
      <p class="reveal">Start your free scan now and experience a safer web</p>
      <a href="#trial" class="btn-primary btn-lg reveal">Start Free Trial ↗</a>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="section" id="contact" aria-labelledby="trust2-heading">
    <div class="container">
      <h2 id="trust2-heading" class="section-title reveal">Trusted by Businesses <em>World Wide</em></h2>
      <p class="section-sub reveal">Clixerfy protects thousands of campaigns globally. Whether you are a local service provider or a multinational e-commerce giant, our mission remains the same</p>
      <div class="testimonials" role="list">
        {testimonials.map((t, i) => (
          <article class="testi-card reveal" style={`transition-delay:${i*70}ms`} role="listitem">
            <div class="testi-meta">
              <div class="avatar" aria-hidden="true">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="#e63030"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
              </div>
              <div>
                <strong class="testi-name">{t.name}</strong>
                <span class="testi-role">{t.role}</span>
              </div>
            </div>
            <div class="stars" role="img" aria-label={`${t.stars} out of 5 stars`}>{"★".repeat(t.stars)}</div>
            <p class="testi-text">{t.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

</main>

<!-- ── FOOTER ── -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo footer-logo" aria-label="Clixerfy home">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#e63030" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <span>clixerfy</span>
      </a>
      <p class="footer-tagline">All-in-one web security solutions to protect your website from threats, malware and fraud</p>
      <div class="socials" aria-label="Social media links">
        {['f','t','in','yt','ig'].map(s => (
          <a href="#" class="social-link" aria-label={s} rel="noopener noreferrer">{s}</a>
        ))}
      </div>
    </div>

    {Object.entries(footerLinks).map(([group, links]) => (
      <div class="footer-col">
        <h3 class="footer-heading">{group}</h3>
        <ul role="list">
          {links.map(link => <li><a href="#" class="footer-link">{link}</a></li>)}
        </ul>
      </div>
    ))}

    <div class="footer-newsletter">
      <h3 class="footer-heading">Subscribe to our newsletter</h3>
      <p>Get the latest security tips and product updates</p>
      <div class="newsletter-form" role="form" aria-label="Newsletter subscription">
        <label for="email-input" class="sr-only">Email address</label>
        <input id="email-input" type="email" placeholder="Enter your email" autocomplete="email" />
        <button type="button" class="btn-primary newsletter-btn">Subscribe</button>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>© 2025 Clixerfy. All rights reserved. Built for the modern web.</p>
    </div>
  </div>
</footer>

</Base>

<style>
  /* ════════════════════════════════════
     ALL CSS IS INLINED BY ASTRO BUILD
     → zero render-blocking external sheets
     ════════════════════════════════════ */

  /* ── Layout helpers ── */
  .container { max-width: 1160px; margin-inline: auto; padding-inline: clamp(1rem, 4vw, 2rem); }
  .section    { padding-block: clamp(3.5rem, 7vw, 6rem); }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: .04em;
    text-align: center;
    margin-bottom: .5rem;
  }
  .section-title em, h2 em { font-style: normal; color: var(--red); }
  .section-sub {
    text-align: center; color: var(--muted);
    max-width: 600px; margin-inline: auto; margin-bottom: 2.75rem; font-size: .93rem;
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 22px;
    background: var(--red); color: #fff;
    font-weight: 600; font-size: .88rem;
    border-radius: 8px;
    /* transition only on background — no layout prop */
    transition: background .18s;
  }
  .btn-primary:hover { background: var(--red-dim, #b82222); }
  .btn-lg { padding: 13px 28px; font-size: .97rem; border-radius: 10px; }

  /* ── NAV ── */
  .nav-wrap {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,10,10,.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav { display: flex; align-items: center; gap: 1.25rem; height: 62px; }
  .logo {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-head); font-size: 1.3rem; font-weight: 800; letter-spacing: .04em;
    flex-shrink: 0;
  }
  .nav-links { display: flex; list-style: none; gap: .2rem; margin-inline: auto; }
  .nav-link {
    padding: 5px 13px; border-radius: 30px;
    font-size: .86rem; font-weight: 500; color: var(--muted);
    transition: color .15s, background .15s;
  }
  .nav-link:hover, .nav-link.active { color: var(--text); background: rgba(255,255,255,.06); }
  .nav-link.active { background: rgba(230,48,48,.14); color: var(--red); }
  .nav-hamburger { display: none; flex-direction: column; gap: 5px; padding: 8px; margin-left: auto; }
  .nav-hamburger span { display: block; width: 21px; height: 2px; background: var(--text); border-radius: 2px; }
  .nav-cta { margin-left: auto; white-space: nowrap; }

  @media (max-width: 768px) {
    .nav-hamburger { display: flex; }
    .nav-links {
      display: none; position: absolute; top: 62px; left: 0; right: 0;
      background: rgba(10,10,10,.97); flex-direction: column;
      padding: 1.25rem 2rem; gap: .5rem;
      border-bottom: 1px solid var(--border);
    }
    .nav-links.open { display: flex; }
    .nav-cta { display: none; }
  }

  /* ── HERO ──
     Static gradient background — no animated blobs.
     Blob animations caused 5s of Style&Layout work on mobile.
  */
  .hero {
    position: relative; overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }
  .hero-bg {
    position: absolute; inset: 0; pointer-events: none;
    /* Static radial gradient — identical visual, zero reflow */
    background:
      radial-gradient(ellipse 70% 60% at 75% 40%, rgba(230,48,48,.14) 0%, transparent 70%),
      radial-gradient(ellipse 45% 45% at 15% 80%, rgba(92,0,0,.18) 0%, transparent 65%),
      linear-gradient(180deg, #0a0a0a 0%, #0d0000 60%, #0a0a0a 100%);
  }
  /* Dot grid overlay — pure CSS, no animation */
  .hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .hero-inner {
    position: relative;
    display: grid; grid-template-columns: 1fr auto;
    gap: 3rem; align-items: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    border: 1px solid rgba(230,48,48,.28); color: var(--muted);
    font-size: .8rem; padding: 5px 13px; border-radius: 30px;
    background: rgba(230,48,48,.05); margin-bottom: 1.4rem;
  }
  /* H1 — LCP element: no opacity:0, no transform at paint time */
  .hero-content h1 {
    font-family: var(--font-head);
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800; line-height: 1.1;
    letter-spacing: .03em;
    margin-bottom: 1.1rem; max-width: 580px;
  }
  .hero-content h1 em { font-style: normal; color: var(--red); }
  .hero-sub   { color: var(--muted); max-width: 430px; margin-bottom: 1.8rem; font-size: .97rem; }
  .hero-actions { margin-bottom: 1.4rem; }
  .hero-trust { display: flex; gap: 1.4rem; flex-wrap: wrap; }
  .hero-trust span { display: flex; align-items: center; gap: 6px; font-size: .8rem; color: var(--muted); }

  /* Shield — only translateY animation (GPU composited, no reflow) */
  .hero-visual  { flex-shrink: 0; }
  .shield-wrap  { position: relative; width: 210px; height: 250px; display: flex; align-items: center; justify-content: center; }
  .ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(230,48,48,.18);
    /* NO rotation animation — caused layout reflow on mobile */
  }
  .ring-1 { width: 190px; height: 190px; }
  .ring-2 { width: 250px; height: 250px; border-style: dashed; opacity: .5; }
  /* translateY only = GPU composited */
  .shield-icon { filter: drop-shadow(0 0 32px rgba(230,48,48,.45)); animation: float 6s ease-in-out infinite; }
  .dot {
    position: absolute; width: 7px; height: 7px; border-radius: 50%;
    background: var(--red);
    animation: blink 2.2s ease-in-out infinite;
  }
  .dot-a { top: 22px; right: 32px; }
  .dot-b { bottom: 38px; left: 16px; animation-delay: .75s; }
  .dot-c { top: 48%; right: 6px;   animation-delay: 1.5s; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
  }

  /* ── FEATURES GRID ── */
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    margin-top: 2.75rem;
  }
  .feat-card       { background: var(--card); padding: 1.75rem; }
