---
import Base from '../layouts/Base.astro';
import { getHomepage } from '../lib/content';

const home = await getHomepage();
---
<Base>

<main id="home">

  <!-- ── HERO ── -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-particles" aria-hidden="true"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-badge">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/></svg>
          {home.hero.badge}
        </div>
        <h1 id="hero-heading">
          {home.hero.titleText}<em>{home.hero.titleHighlight}</em>
        </h1>
        <p class="hero-sub">{home.hero.subtitle}</p>
        <div class="hero-actions">
          <a href={home.hero.ctaHref} id="trial" class="btn-primary btn-lg">{home.hero.ctaLabel}</a>
        </div>
        <div class="hero-trust">
          {home.hero.trustBadges.map(badge => (
            <span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/></svg>
              {badge.text}
            </span>
          ))}
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="shield-glow"></div>
        <svg class="shield-icon" width="160" height="190" viewBox="0 0 120 140" fill="none">
          <path d="M60 5 L110 25 L110 75 C110 105 85 130 60 138 C35 130 10 105 10 75 L10 25 Z" fill="var(--red)" opacity="0.2" stroke="var(--red)" stroke-width="1.5"/>
          <path d="M60 18 L100 34 L100 75 C100 100 80 122 60 130 C40 122 20 100 20 75 L20 34 Z" fill="var(--red)" opacity="0.35"/>
          <rect x="48" y="55" width="24" height="30" rx="3" fill="none" stroke="#fff" stroke-width="3"/>
          <circle cx="60" cy="67" r="4" fill="#fff"/>
          <line x1="60" y1="71" x2="60" y2="78" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ── FEATURES GRID ── -->
  <section class="section" id="about" aria-labelledby="feat1-heading">
    <div class="container">
      <h2 id="feat1-heading" class="section-title reveal text-right" set:html={home.features.sectionTitle}></h2>
      <div class="feat-grid">
        {home.features.items.map((f, i) => (
          <article class={`feat-card reveal ${f.large ? 'feat-large' : ''}`} style={`transition-delay:${i*60}ms`}>
            <div class="feat-dot" aria-hidden="true"></div>
            <h3 class="feat-title">{f.title}</h3>
            <p class="feat-desc">{f.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WHY TRUST ── -->
  <section class="section trust-section" id="why" aria-labelledby="trust-heading">
    <div class="container">
      <div class="trust-inner">
        <div class="trust-copy reveal">
          <h2 id="trust-heading" set:html={home.trust.sectionTitle}></h2>
          <p>{home.trust.body}</p>
        </div>
        <div class="stats-row" role="list">
          {home.trust.stats.map((s, i) => (
            <div class="stat-item reveal" style={`transition-delay:${i*55}ms`} role="listitem">
              <div class="stat-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </div>
              <strong class="stat-value">{s.value}</strong>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─ PRODUCTS ── -->
  <section class="section" id="products" aria-labelledby="prod-heading">
    <div class="container">
      <h2 id="prod-heading" class="section-title reveal text-left" set:html={home.products.sectionTitle}></h2>
      <div class="prod-grid">
        {home.products.items.map((p, i) => (
          <article class={`prod-card reveal ${i === 1 ? 'prod-tall' : ''}`} style={`transition-delay:${i*55}ms`}>
            <div class="prod-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </div>
            <h3 class="prod-title">{p.title}</h3>
            <p class="prod-desc">{p.desc}</p>
            <a href="#contact" class="prod-link">{p.linkText} <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── THREAT CARDS ── -->
  <section class="section cards-section" aria-labelledby="cards-heading">
    <div class="container">
      <h2 id="cards-heading" class="section-title reveal text-right" set:html={home.threatCards.sectionTitle}></h2>
      <p class="section-sub reveal">{home.threatCards.sectionSubtitle}</p>
      <div class="threat-cards" role="list">
        {home.threatCards.items.map((c, i) => (
          <article class={`threat-card reveal threat-${i === 0 ? 'red' : i === 1 ? 'white' : 'dark'}`} style={`transition-delay:${i*60}ms`} role="listitem">
            <div class="tc-icon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke={i <= 1 ? "var(--red)" : "#fff"} stroke-width="2" stroke-linecap="round"><path d="M12 2L3 7v9c0 5 4.5 9.7 9 11 4.5-1.3 9-6 9-11V7L12 2z"/></svg>
            </div>
            <h3 class="tc-title">{c.title}</h3>
            <p class="tc-desc">{c.desc}</p>
            <a href="#contact" class="tc-link">{c.linkText} <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA BANNER ── -->
  <section class="cta-section" id="pricing" aria-labelledby="cta-heading">
    <div class="cta-bg" aria-hidden="true"></div>
    <div class="container cta-inner">
      <h2 id="cta-heading" class="reveal">{home.cta.title}</h2>
      <p class="reveal">{home.cta.subtitle}</p>
      <a href={home.cta.ctaHref} class="btn-primary btn-lg reveal">{home.cta.ctaLabel}</a>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="section" id="contact" aria-labelledby="trust2-heading">
    <div class="container">
      <h2 id="trust2-heading" class="section-title reveal" set:html={home.testimonials.sectionTitle}></h2>
      <p class="section-sub reveal">{home.testimonials.sectionSubtitle}</p>
      <div class="testimonials" role="list">
        {home.testimonials.items.map((t, i) => (
          <article class="testi-card reveal" style={`transition-delay:${i*70}ms`} role="listitem">
            <div class="testi-meta">
              <div class="avatar" aria-hidden="true">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="var(--red)"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
              </div>
              <div>
                <strong class="testi-name">{t.name}</strong>
                <span class="testi-role">{t.role}</span>
              </div>
            </div>
            <p class="testi-text">{t.text}</p>
            <div class="stars" role="img" aria-label={`${t.stars} out of 5 stars`}>{"★".repeat(t.stars)}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

</main>

</Base>

<style>
  .section { padding-block: clamp(3.5rem, 7vw, 6rem); }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: .04em;
    text-align: center;
    margin-bottom: .5rem;
  }
  .section-title.text-right { text-align: right; }
  .section-title.text-left { text-align: left; }
  .section-title em, h2 em { font-style: normal; color: var(--red); }
  .section-sub {
    text-align: center; color: var(--muted);
    max-width: 600px; margin-inline: auto; margin-bottom: 2.75rem; font-size: .93rem;
  }

  /* ─ HERO ── */
  .hero {
    position: relative; overflow: hidden;
    padding-block: clamp(4rem, 10vw, 8rem);
  }
  .hero-bg {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 60% 50% at 70% 40%, rgba(230,48,48,.12) 0%, transparent 70%),
      linear-gradient(180deg, #0a0a0a 0%, #0d0000 60%, #0a0a0a 100%);
  }
  /* Scattered red particles */
  .hero-particles {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle, rgba(230,48,48,.6) 1px, transparent 1px),
      radial-gradient(circle, rgba(230,48,48,.4) 1.5px, transparent 1.5px),
      radial-gradient(circle, rgba(230,48,48,.3) 1px, transparent 1px),
      radial-gradient(circle, rgba(230,48,48,.5) 2px, transparent 2px),
      radial-gradient(circle, rgba(230,48,48,.25) 1px, transparent 1px);
    background-size:
      120px 80px, 200px 150px, 90px 120px, 250px 180px, 160px 100px;
    background-position:
      10% 20%, 30% 60%, 50% 10%, 70% 70%, 90% 40%;
    opacity: .7;
  }

  .hero-inner {
    position: relative;
    display: grid; grid-template-columns: 1fr auto;
    gap: 3rem; align-items: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    border: 1px solid rgba(230,48,48,.28); color: var(--muted);
    font-size: .8rem; padding: 5px 13px; border-radius: 30px;
    background: rgba(230,48,48,.05); margin-bottom: 1.4rem;
  }
  .hero-content h1 {
    font-family: var(--font-head);
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800; line-height: 1.1;
    letter-spacing: .03em;
    margin-bottom: 1.1rem; max-width: 580px;
  }
  .hero-content h1 em { font-style: normal; color: var(--red); }
  .hero-sub   { color: var(--muted); max-width: 430px; margin-bottom: 1.8rem; font-size: .97rem; }
  .hero-actions { margin-bottom: 1.4rem; }
  .hero-trust { display: flex; gap: 1.4rem; flex-wrap: wrap; }
  .hero-trust span { display: flex; align-items: center; gap: 6px; font-size: .8rem; color: var(--muted); }

  /* Shield visual */
  .hero-visual  { flex-shrink: 0; position: relative; }
  .shield-glow {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(230,48,48,.3) 0%, transparent 70%);
    filter: blur(20px);
  }
  .shield-icon {
    position: relative; z-index: 1;
    filter: drop-shadow(0 0 40px rgba(230,48,48,.5));
    animation: float 6s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
  }

  /* ── FEATURES GRID ── */
  .feat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    margin-top: 2.75rem;
  }
  .feat-card {
    background: var(--card); padding: 1.75rem;
    position: relative;
  }
  .feat-large {
    grid-row: span 2; grid-column: 1;
    background: linear-gradient(135deg, #1a0808, #0e0000);
  }
  .feat-dot {
    width: 28px; height: 28px; border-radius: 50%;
    background: #fff; margin-bottom: 1.2rem;
  }
  .feat-title {
    font-family: var(--font-head); font-size: .82rem; font-weight: 700;
    letter-spacing: .05em; text-transform: uppercase; margin-bottom: .55rem;
  }
  .feat-desc  { font-size: .83rem; color: var(--muted); line-height: 1.65; }
  .feat-large .feat-title { font-size: 1rem; }
  .feat-large .feat-desc  { font-size: .88rem; }

  @media (max-width: 768px) {
    .feat-grid { grid-template-columns: 1fr; }
    .feat-large { grid-column: auto; grid-row: auto; }
  }

  /* ── TRUST / STATS ── */
  .trust-section { background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .trust-inner   { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .trust-copy h2 { font-family: var(--font-head); font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin-bottom: .9rem; }
  .trust-copy p  { color: var(--muted); font-size: .93rem; line-height: 1.8; }
  .stats-row     { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .stat-item     { display: flex; flex-direction: column; gap: .2rem; }
  .stat-icon     { margin-bottom: .4rem; }
  .stat-value    { font-family: var(--font-head); font-size: 1.9rem; font-weight: 800; letter-spacing: .02em; }
  .stat-label    { font-size: .8rem; color: var(--muted); }

  @media (max-width: 768px) { .trust-inner { grid-template-columns: 1fr; gap: 2.5rem; } }

  /* ── PRODUCTS (masonry-style) ─ */
  .prod-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto auto;
    gap: .9rem; margin-top: 2.75rem;
  }
  .prod-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 13px; padding: 1.6rem;
    display: flex; flex-direction: column; gap: .7rem;
    transition: border-color .18s;
  }
  .prod-card:hover { border-color: rgba(230,48,48,.28); }
  .prod-tall {
    grid-row: 1 / 3;
    grid-column: 2;
  }
  .prod-icon  {
    width: 30px; height: 30px; border-radius: 50%;
    background: rgba(230,48,48,.07); border: 1px solid rgba(230,48,48,.14);
    display: flex; align-items: center; justify-content: center;
  }
  .prod-title { font-family: var(--font-head); font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; }
  .prod-desc  { font-size: .81rem; color: var(--muted); flex: 1; line-height: 1.65; }
  .prod-link  { font-size: .8rem; color: var(--red); font-weight: 600; align-self: flex-start; display: flex; gap: 4px; transition: gap .15s; }
  .prod-link:hover { gap: 8px; }

  @media (max-width: 768px) {
    .prod-grid { grid-template-columns: 1fr 1fr; }
    .prod-tall { grid-row: auto; grid-column: auto; }
  }
  @media (max-width: 480px) { .prod-grid { grid-template-columns: 1fr; } }

  /* ── THREAT CARDS ── */
  .cards-section { background: var(--card); border-top: 1px solid var(--border); }
  .threat-cards  {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: .9rem; margin-top: 2.75rem;
  }
  .threat-card {
    border: 1px solid var(--border); border-radius: 13px;
    padding: 1.6rem; display: flex; flex-direction: column; gap: .7rem;
    transition: border-color .18s, transform .18s;
  }
  .threat-card:hover { transform: translateY(-2px); }
  .threat-red {
    background: linear-gradient(135deg, var(--red), var(--red-dim));
    border-color: rgba(230,48,48,.5);
  }
  .threat-red .tc-title { color: #fff; }
  .threat-red .tc-desc { color: rgba(255,255,255,.85); }
  .threat-red .tc-link { color: rgba(255,255,255,.9); }
  .threat-white {
    background: var(--card);
    border-color: var(--border);
  }
  .threat-white .tc-title { color: var(--red); }
  .threat-white .tc-desc { color: var(--muted); }
  .threat-white .tc-link { color: var(--red); }
  .threat-dark {
    background: var(--card);
  }
  .tc-icon  {
    width: 30px; height: 30px; border-radius: 7px;
    background: rgba(230,48,48,.09); display: flex; align-items: center; justify-content: center;
  }
  .threat-red .tc-icon { background: rgba(255,255,255,.15); }
  .threat-white .tc-icon { background: rgba(230,48,48,.1); }
  .tc-title { font-family: var(--font-head); font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--red); }
  .tc-desc  { font-size: .81rem; color: var(--muted); flex: 1; line-height: 1.65; }
  .tc-link  { font-size: .8rem; color: var(--muted); font-weight: 600; display: flex; gap: 4px; transition: color .15s; }
  .tc-link:hover { color: var(--red); }

  @media (max-width: 900px) { .threat-cards { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .threat-cards { grid-template-columns: 1fr; } }

  /* ── CTA ── */
  .cta-section {
    padding-block: clamp(3.5rem, 8vw, 5.5rem); text-align: center;
    position: relative; overflow: hidden;
  }
  .cta-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, #0a3d5c 0%, #0d5a7a 25%, #1a1a2e 50%, #3d0a0a 75%, #1a0202 100%);
  }
  .cta-bg::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 50% 80% at 20% 50%, rgba(10,80,120,.6) 0%, transparent 70%),
      radial-gradient(ellipse 50% 80% at 80% 50%, rgba(120,10,10,.5) 0%, transparent 70%);
  }
  .cta-inner {
    position: relative; display: flex; flex-direction: column;
    align-items: center; gap: 1.1rem;
  }
  .cta-inner h2 { font-family: var(--font-head); font-size: clamp(1.9rem, 4.5vw, 3.2rem); font-weight: 800; letter-spacing: .04em; color: #fff; }
  .cta-inner p  { color: rgba(255,255,255,.7); max-width: 420px; font-size: .93rem; }

  /* ─ TESTIMONIALS ── */
  .testimonials {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem; margin-top: 2.75rem;
  }
  .testi-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 13px; padding: 1.6rem;
    display: flex; flex-direction: column; gap: .7rem;
    transition: border-color .18s;
  }
  .testi-card:hover { border-color: rgba(230,48,48,.22); }
  .testi-meta  { display: flex; align-items: center; gap: .7rem; }
  .avatar      {
    width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;
    background: rgba(230,48,48,.09); border: 1px solid rgba(230,48,48,.18);
    display: flex; align-items: center; justify-content: center;
  }
  .testi-name  { display: block; font-weight: 600; font-size: .88rem; }
  .testi-role  { display: block; font-size: .76rem; color: var(--muted); }
  .stars       { color: var(--red); font-size: .82rem; letter-spacing: 2px; margin-top: auto; }
  .testi-text  { font-size: .86rem; color: var(--muted); line-height: 1.72; }

  @media (max-width: 768px) { .testimonials { grid-template-columns: 1fr; } }
</style>
