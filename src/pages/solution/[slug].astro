---
import Base from '../../layouts/Base.astro';
import { getSolutionPage, getSolutionSlugs } from '../../lib/content';
import { richTextToHtml } from '../../lib/strapi';
import { getResponsiveSrcSet, getResponsiveSizes } from '../../lib/images';

export async function getStaticPaths() {
  try {
    const slugs = await getSolutionSlugs();
    return slugs.map(slug => ({ params: { slug } }));
  } catch { return []; }
}

const { slug } = Astro.params;
const solution = await getSolutionPage(slug!);

// Extract data from each section array
// Find hero with featured image, or use first one
const hero = solution.herosection?.find((h: any) => h.featuredimage) ?? solution.herosection?.[0] ?? null;
const richtextBlocks = solution.Richtext ?? [];
const featureBlocks = solution.features ?? [];
const processBlocks = solution.process ?? [];
const protectionBlocks = solution.protections ?? [];
const benefitBlocks = solution.benefits ?? [];
const statsBlocks = solution.stats ?? [];
const faqItems = solution.faqs?.[0]?.faq ?? [];
const ctaBlock = solution.cta?.[0] ?? null;
const pricingTable = solution.PricingTable ?? null;
---
<Base title={solution.metaTitle || solution.title} description={solution.metaDescription}>
<main>

  {/* Hero Section */}
  {hero && (
    <section class="sol-hero">
      <div class="sol-hero-bg" aria-hidden="true" style={hero.bgimage ? `background-image: url(${hero.bgimage}); background-size: cover; background-position: center;` : ''}><div class="sol-hero-particles" aria-hidden="true"></div></div>
      <div class="container sol-hero-inner">
        <div class="sol-hero-content">
          {hero.titleText && <h1>{hero.titleText}</h1>}
          {hero.subtitle && <div class="sol-hero-sub" set:html={richTextToHtml(hero.subtitle)}></div>}
          {hero.richtext && <div class="sol-hero-richtext" set:html={richTextToHtml(hero.richtext)}></div>}
        </div>
        {hero.featuredimage && <div class="sol-hero-visual"><div class="sol-hero-frame"><img src={hero.featuredimage} alt={hero.titleText} width="600" height="400" loading="eager" decoding="async" fetchpriority="high" srcset={getResponsiveSrcSet(hero.featuredimage)} sizes={getResponsiveSizes(600)} /></div></div>}
      </div>
    </section>
  )}

  {/* Richtext Sections */}
  {richtextBlocks.map((block: any) => (
    <section class="section sol-richtext-section">
      <div class="container">
        {block.title && <h2 class="section-title reveal">{block.title}</h2>}
        {block.subtitle && <p class="section-sub reveal">{block.subtitle}</p>}
        {block.bodycontent && <div class="sol-richtext-content reveal" set:html={richTextToHtml(block.bodycontent)}></div>}
        {block.child && block.child.length > 0 && (
          <div class="sol-richtext-grid">
            {block.child.map((item: any, i: number) => (
              <article class="sol-richtext-card reveal" style={`transition-delay:${i * 80}ms`}>
                {item.icon?.iconData && (
                  <div class="sol-richtext-icon">
                    <svg viewBox={`0 0 ${item.icon.width || 28} ${item.icon.height || 28}`} set:html={item.icon.iconData} />
                  </div>
                )}
                {item.title && <h3 class="sol-richtext-title">{item.title}</h3>}
                {item.subtitle && <p class="sol-richtext-sub">{item.subtitle}</p>}
                {item.body && <div class="sol-richtext-body" set:html={richTextToHtml(item.body)}></div>}
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  {/* Features Sections */}
  {featureBlocks.map((block: any) => (
    <section class="section sol-features-section">
      <div class="container">
        {block.sectionTitle && <h2 class="section-title reveal">{block.sectionTitle}</h2>}
        {block.body && <div class="sol-features-body reveal" set:html={richTextToHtml(block.body)}></div>}
        {block.items && block.items.length > 0 && (
          <div class="sol-features-grid">
            {block.items.map((item: any, i: number) => (
              <article class="sol-feature-card reveal" style={`transition-delay:${i * 70}ms`}>
                {item.icon?.iconData && (
                  <div class="sol-feature-icon">
                    <svg viewBox={`0 0 ${item.icon.width || 28} ${item.icon.height || 28}`} set:html={item.icon.iconData} />
                  </div>
                )}
                {item.title && <h3 class="sol-feature-title">{item.title}</h3>}
                {item.desc && <div class="sol-feature-desc">{item.desc}</div>}
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  {/* Process Section */}
  {processBlocks.length > 0 && processBlocks.map((block: any) => (
    <section class="section sol-process-section">
      <div class="container">
        {block.title && <h2 class="section-title reveal">{block.title}</h2>}
        {block.steps && block.steps.length > 0 && (
          <div class="sol-process-steps">
            {block.steps.map((step: any, i: number) => (
              <div class="sol-process-step reveal" style={`transition-delay:${i * 100}ms`}>
                {/* <div class="sol-step-number">{String(i + 1).padStart(2, '0')}</div> */}
                <div class="sol-step-content"><h3>{step.title}</h3>{step.description && <div set:html={richTextToHtml(step.description)}></div>}</div>
                {step.imageUrl && <div class="sol-step-image"><img src={step.imageUrl} alt={step.title} width="200" height="160" /></div>}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  {/* Protection Levels Section */}
  {protectionBlocks.length > 0 && protectionBlocks.map((block: any) => (
    <section class="section sol-levels-section">
      <div class="container">
        {block.title && <h2 class="section-title reveal">{block.title}</h2>}
        {block.level && block.level.length > 0 && (
          <div class="sol-levels-grid">
            {block.level.map((item: any, i: number) => (
              <article class={`sol-level-card reveal sol-level-${i}`} style={`transition-delay:${i * 80}ms`}>
                {item.iconUrl && <div class="sol-level-icon"><img src={item.iconUrl} alt="" width="32" height="32" /></div>}
                <h3>{item.title}</h3><p>{item.description}</p>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  {/* Benefits Section */}
  {benefitBlocks.length > 0 && benefitBlocks.map((block: any) => (
    <section class="section sol-benefits-section">
      <div class="container">
        {block.title && <h2 class="section-title reveal">{block.title}</h2>}
        {block.benefit && block.benefit.length > 0 && (
          <div class="sol-benefits-grid">
            {block.benefit.map((item: any, i: number) => (
              <div class="sol-benefit-item reveal" style={`transition-delay:${i * 60}ms`}>
                {item.iconUrl && <div class="sol-benefit-icon"><img src={item.iconUrl} alt="" width="24" height="24" /></div>}
                <div><h3>{item.title}</h3><p>{item.description}</p></div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  {/* Stats Section */}
  {statsBlocks.length > 0 && statsBlocks.map((block: any) => (
    <section class="sol-stats-section">
      <div class="container">
        {block.stats && block.stats.length > 0 && (
          <div class="sol-stats-row">
            {block.stats.map((item: any, i: number) => (
              <div class="sol-stat reveal" style={`transition-delay:${i * 60}ms`}>
                <strong class="sol-stat-value">{item.value}</strong><span class="sol-stat-label">{item.label}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  {/* Pricing Table Section */}
  {pricingTable && pricingTable.plans && pricingTable.plans.length > 0 && (
    <section class="section sol-pricing-section">
      <div class="container">
        {pricingTable.title && <h2 class="section-title reveal">{pricingTable.title}</h2>}
        {pricingTable.subtitle && <div class="section-sub reveal" set:html={richTextToHtml(pricingTable.subtitle)}></div>}
        <div class="sol-pricing-grid">
          {pricingTable.plans.map((plan: any, i: number) => (
            <article class={`sol-pricing-card reveal ${plan.featured ? 'sol-pricing-featured' : ''}`} style={`transition-delay:${i * 100}ms`}>
              {plan.featured && <div class="sol-pricing-badge">Most Popular</div>}
              {plan.name && <h3 class="sol-pricing-name">{plan.name}</h3>}
              <div class="sol-pricing-prices">
                {plan.monthlyPrice && <div class="sol-pricing-monthly">{plan.monthlyPrice}</div>}
                {plan.annualPrice && <div class="sol-pricing-annual">{plan.annualPrice}</div>}
              </div>
              {plan.features && plan.features.length > 0 && (
                <ul class="sol-pricing-features">
                  {plan.features.map((f: any) => (
                    <li class="sol-pricing-feature">
                      <span class="sol-pricing-feature-label">{f.label}</span>
                      <span class="sol-pricing-feature-value">{f.value}</span>
                    </li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* FAQ Section */}
  {faqItems.length > 0 && (
    <section class="section sol-faq-section">
      <div class="container">
        <h2 class="section-title reveal">{solution.faqs?.[0]?.title || 'Frequently Asked Questions'}</h2>
        <div class="sol-faq-list">
          {faqItems.map((item: any, i: number) => (
            <details class="sol-faq-item reveal" style={`transition-delay:${i * 60}ms`}>
              <summary>{item.question}</summary>{item.answer && <div set:html={richTextToHtml(item.answer)}></div>}
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* CTA Section - only render if has title */}
  {ctaBlock && ctaBlock.title && (
    <section class="sol-cta-section">
      <div class="sol-cta-bg" aria-hidden="true"></div>
      <div class="container sol-cta-inner">
        <h2 class="reveal">{ctaBlock.title}</h2>
        {ctaBlock.subtitle && <p class="reveal">{ctaBlock.subtitle}</p>}
        {ctaBlock.ctaLabel && <a href={ctaBlock.ctaHref} class="btn-primary btn-lg reveal">{ctaBlock.ctaLabel}</a>}
      </div>
    </section>
  )}

</main>
</Base>

<style>
  .section { padding-block: clamp(3.5rem, 7vw, 6rem); }
  .section-title { font-family: var(--font-head); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; letter-spacing: .04em; text-align: center; margin-bottom: .5rem; }
  .section-sub { text-align: center; color: var(--muted); max-width: 600px; margin-inline: auto; margin-bottom: 2.75rem; font-size: .93rem; }
  .sol-hero { position: relative; overflow: hidden; padding-block: clamp(4rem, 10vw, 7rem); }
  .sol-hero-bg { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(230,48,48,.14) 0%, transparent 70%), linear-gradient(180deg, #0a0a0a 0%, #0d0000 60%, #0a0a0a 100%); background-blend-mode: overlay; }
  .sol-hero-bg::before { content: ''; position: absolute; inset: 0; background: inherit; background-size: cover; background-position: center; opacity: 0.4; }
  .sol-hero-bg::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(230,48,48,.14) 0%, transparent 70%), linear-gradient(180deg, rgba(10,10,10,0.85) 0%, rgba(13,0,0,0.9) 60%, rgba(10,10,10,0.95) 100%); }
  .sol-hero-particles { position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(230,48,48,.65) 1px, transparent 1px), radial-gradient(circle, rgba(230,48,48,.4) 1.5px, transparent 1.5px); background-size: 120px 80px, 200px 150px; opacity: .7; }
  .sol-hero-inner { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .sol-badge { display: inline-flex; align-items: center; gap: 7px; border: 1px solid rgba(230,48,48,.28); color: var(--muted); font-size: .8rem; padding: 5px 13px; border-radius: 30px; background: rgba(230,48,48,.06); margin-bottom: 1.4rem; }
  .sol-hero-content h1 { font-family: var(--font-head); font-size: clamp(2.2rem, 5vw, 3.6rem); font-weight: 800; line-height: 1.1; margin-bottom: 1.1rem; max-width: 540px; }
  .sol-hero-sub { color: var(--muted); max-width: 480px; margin-bottom: 1.8rem; font-size: .97rem; line-height: 1.7; }
  .sol-hero-sub p { margin-bottom: .6rem; } .sol-hero-sub strong { color: #fff; }
  .sol-hero-visual { display: flex; align-items: center; justify-content: center; }
  .sol-hero-frame { width: 100%; max-width: 560px; border-radius: 16px; overflow: hidden; border: 1px solid rgba(230,48,48,.22); box-shadow: 0 0 50px rgba(230,48,48,.18); }
  .sol-hero-frame img { width: 100%; height: auto; display: block; }
  @media (max-width: 768px) { .sol-hero-inner { grid-template-columns: 1fr; text-align: center; } .sol-hero-content h1, .sol-hero-sub { max-width: 100%; } .sol-hero-sub { margin-inline: auto; } .sol-hero-visual { order: -1; } .sol-hero-frame { max-width: 320px; } }
  .sol-content-section { background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .sol-content-inner { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }
  .sol-content-copy h2 { font-family: var(--font-head); font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin-bottom: .9rem; }
  .sol-content-copy div { color: var(--muted); font-size: .93rem; line-height: 1.8; } .sol-content-copy strong { color: #fff; }
  .sol-content-image { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); } .sol-content-image img { width: 100%; height: auto; display: block; }
  @media (max-width: 768px) { .sol-content-inner { grid-template-columns: 1fr; gap: 2.5rem; } }
  .sol-features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-top: 2.75rem; }
  .sol-feature-card { background: var(--card); border: 1px solid white; border-radius: 14px; padding: 2rem; display: flex; flex-direction: column; gap: .7rem; transition: border-color .18s, transform .18s; }
  .sol-feature-card:hover { border-color: var(--brand-color); transform: translateY(-2px); } .sol-feature-card:hover .sol-feature-icon svg { color: var(--brand-color); }
  .sol-feature-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(230,48,48,.08); border: 1px solid ; display: flex; align-items: center; justify-content: center; } .sol-feature-icon svg { width: 26px; height: 26px; }
  .sol-feature-title { font-family: var(--font-head); font-size: 1rem; font-weight: 700; }
  .sol-feature-desc { font-size: .88rem; color: var(--muted); line-height: 1.75; } .sol-feature-desc strong { color: #fff; }
  @media (max-width: 768px) { .sol-features-grid { grid-template-columns: 1fr; } }
    .sol-richtext-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; margin-top: 2.75rem; }
    .sol-richtext-card { background: var(--card); border: 1px solid white; border-radius: 14px; padding: 2rem; display: flex; flex-direction: column; gap: .8rem; transition: border-color .18s, transform .18s; }
    .sol-richtext-card:hover { border-color: var(--brand-color); transform: translateY(-2px); } .sol-richtext-card:hover .sol-richtext-icon svg { color: var(--brand-color); }
    .sol-richtext-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(230,48,48,.08); border: 1px solid; display: flex; align-items: center; justify-content: center; } .sol-richtext-icon svg { width: 26px; height: 26px; }
    .sol-richtext-title { font-family: var(--font-head); font-size: 1.05rem; font-weight: 700; }
    .sol-richtext-sub { font-size: .85rem; color: var(--muted); line-height: 1.7; }
    .sol-richtext-body { font-size: .88rem; color: var(--muted); line-height: 1.75; } .sol-richtext-body strong { color: #fff; }
    @media (max-width: 768px) { .sol-richtext-grid { grid-template-columns: 1fr; } }
  .sol-process-steps { display: flex; flex-direction: column; gap: 2.5rem; margin-top: 2.75rem; max-width: 800px; margin-inline: auto; }
  .sol-process-step { display: grid; grid-template-columns: auto 1fr auto; gap: 1.5rem; align-items: center; background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 1.8rem; transition: border-color .18s; }
  .sol-process-step:hover { border-color: var(--brand-color); }
  .sol-step-number { font-family: var(--font-head); font-size: 2.4rem; font-weight: 800; color: var(--brand-color); opacity: .5; line-height: 1; min-width: 50px; }
  .sol-step-content h3 { font-family: var(--font-head); font-size: 1.05rem; font-weight: 700; margin-bottom: .4rem; }
  .sol-step-content div { font-size: .88rem; color: var(--muted); line-height: 1.7; } .sol-step-content strong { color: #fff; }
  .sol-step-image { border-radius: 10px; overflow: hidden; max-width: 180px; } .sol-step-image img { width: 100%; height: auto; display: block; }
  @media (max-width: 768px) { .sol-process-step { grid-template-columns: auto 1fr; } .sol-step-image { grid-column: 1 / -1; max-width: 100%; } }
  .sol-levels-section { background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .sol-levels-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-top: 2.75rem; }
  .sol-level-card { border: 1px solid var(--border); border-radius: 14px; padding: 2rem; display: flex; flex-direction: column; gap: .7rem; text-align: center; transition: transform .18s; }
  .sol-level-card:hover { transform: translateY(-3px); }
  .sol-level-0 { border-color: rgba(230,48,48,.15); } .sol-level-1 { border-color: rgba(230,48,48,.35); background: rgba(230,48,48,.04); } .sol-level-2 { border-color: rgba(230,48,48,.55); background: rgba(230,48,48,.08); }
  .sol-level-icon { width: 56px; height: 56px; border-radius: 50%; margin: 0 auto; background: rgba(230,48,48,.08); border: 1px solid rgba(230,48,48,.16); display: flex; align-items: center; justify-content: center; } .sol-level-icon img { width: 28px; height: 28px; }
  .sol-level-card h3 { font-family: var(--font-head); font-size: 1.1rem; font-weight: 700; } .sol-level-card p { font-size: .88rem; color: var(--muted); line-height: 1.7; }
  @media (max-width: 768px) { .sol-levels-grid { grid-template-columns: 1fr; } }
  .sol-benefits-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; margin-top: 2.75rem; }
  .sol-benefit-item { display: flex; align-items: flex-start; gap: 1rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; transition: border-color .18s; }
  .sol-benefit-item:hover { border-color: var(--brand-color); }
  .sol-benefit-icon { width: 42px; height: 42px; border-radius: 10px; flex-shrink: 0; background: rgba(230,48,48,.08); border: 1px solid rgba(230,48,48,.16); display: flex; align-items: center; justify-content: center; } .sol-benefit-icon img { width: 22px; height: 22px; }
  .sol-benefit-item h3 { font-family: var(--font-head); font-size: .92rem; font-weight: 700; margin-bottom: .3rem; } .sol-benefit-item p { font-size: .85rem; color: var(--muted); line-height: 1.65; }
  @media (max-width: 768px) { .sol-benefits-grid { grid-template-columns: 1fr; } }
  .sol-stats-section { padding-block: clamp(3rem, 6vw, 4.5rem); background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .sol-stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center; }
  .sol-stat { display: flex; flex-direction: column; gap: .3rem; }
  .sol-stat-value { font-family: var(--font-head); font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; color: var(--brand-color); }
  .sol-stat-label { font-size: .82rem; color: var(--muted); }
  @media (max-width: 768px) { .sol-stats-row { grid-template-columns: 1fr 1fr; } }
  .sol-faq-list { display: flex; flex-direction: column; gap: .8rem; margin-top: 2.75rem; max-width: 760px; margin-inline: auto; }

  /* Pricing Table */
  .sol-pricing-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem; margin-top: 2.75rem; align-items: stretch; }
.sol-pricing-card {
  flex: 1 1 0;
  min-width: 280px;
  max-width: 100%;

  position: relative;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
  padding: 2.5rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: border-color .18s, transform .18s, background .18s;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
}  
.sol-pricing-card:hover { border-color: var(--brand-color); transform: translateY(-4px); }
  .sol-pricing-card.sol-pricing-featured { border-color: var(--brand-color); background: linear-gradient(180deg, rgba(230,48,48,.08) 0%, rgba(255,255,255,0.03) 100%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); transform: scale(1.05); box-shadow: 0 8px 32px rgba(230,48,48,.15); }
  .sol-pricing-card.sol-pricing-featured:hover { transform: scale(1.05) translateY(-4px); }
  .sol-pricing-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--brand-color); color: #fff; font-size: .75rem; font-weight: 700; padding: 4px 14px; border-radius: 20px; white-space: nowrap; }
  .sol-pricing-name { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--brand-color); }
  .sol-pricing-prices { display: flex; flex-direction: column; gap: .5rem; }
  .sol-pricing-monthly { font-size: 1.4rem; font-weight: 800; color: #fff; }
  .sol-pricing-annual { font-size: .85rem; color: var(--muted); }
  .sol-pricing-features { list-style: none; padding: 0; margin: 1.5rem 0 0; width: 100%; border-top: 1px solid var(--border); padding-top: 1.5rem; display: flex; flex-direction: column; gap: .75rem; }
  .sol-pricing-feature { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; font-size: .85rem; }
  .sol-pricing-feature-label { color: var(--muted); text-align: left;}
  .sol-pricing-feature-value { font-weight: 600; color: #fff; text-align: right; }
